{
  "$schema": "https://design-tokens.github.io/community-group/format/draft/",
  "$description": "kesson-space core design tokens (--ds-* namespace, shared with creation-space / awareness-space). Scope: base tokens only (color / font / fontSize / letterSpacing / radius / transition); component-derived tokens (focus-ring / card-border / card-shadow など) は tokens.css 側で参照のこと. ks 固有 extended color tokens (#181) を含む. Source: src/styles/tokens.css. Format: W3C Design Tokens Community Group draft.",
  "color": {
    "bg-body":     { "$value": "#050508",            "$type": "color", "$description": "Body background (deep dark)" },
    "accent":      { "$value": "rgb(100, 150, 255)", "$type": "color", "$description": "Primary accent (links, focus, emphasis)" },
    "heading":     { "$value": "rgb(255, 255, 255)", "$type": "color", "$description": "Heading text color" },
    "sub-text":    { "$value": "rgb(180, 200, 230)", "$type": "color", "$description": "Secondary text" },
    "highlight":   { "$value": "rgb(220, 230, 245)", "$type": "color", "$description": "Highlight" },
    "link":        { "$value": "rgb(130, 170, 255)", "$type": "color", "$description": "Link" },
    "error":       { "$value": "#f87171",            "$type": "color", "$description": "Error" },
    "accent-soft":   { "$value": "rgb(150, 190, 245)", "$type": "color", "$description": "ks 固有 (#181): card cover-note ソフト accent" },
    "focus-ring":    { "$value": "rgb(150, 190, 255)", "$type": "color", "$description": "ks 固有 (#181): section heading focus ring" },
    "nav-gem":       { "$value": "rgb(180, 195, 240)", "$type": "color", "$description": "ks 固有 (#181): nav-label--gem base" },
    "nav-gem-hover": { "$value": "rgb(200, 215, 255)", "$type": "color", "$description": "ks 固有 (#181): nav-label--gem hover" },
    "embed-handle":  { "$value": "rgb(200, 215, 245)", "$type": "color", "$description": "ks 固有 (#181): x-embed-handle" }
  },
  "font": {
    "serif-display": { "$value": "Noto Serif JP, Yu Mincho, MS PMincho, serif", "$type": "fontFamily" },
    "serif-ui":      { "$value": "Georgia, Noto Serif JP, serif",               "$type": "fontFamily" },
    "mono-ui":       { "$value": "SF Mono, Fira Code, Consolas, monospace",     "$type": "fontFamily" }
  },
  "fontSize": {
    "ui-xs":          { "$value": "0.85rem",                          "$type": "dimension" },
    "ui-sm":          { "$value": "0.88rem",                          "$type": "dimension" },
    "ui-arrow":       { "$value": "clamp(0.7rem, 3.5vmin, 1.2rem)",   "$type": "dimension" },
    "h1":             { "$value": "clamp(1.0rem, 5.5vmin, 2.0rem)",   "$type": "dimension" },
    "section-heading":{ "$value": "0.88rem",                          "$type": "dimension" },
    "card-title":     { "$value": "1.0rem",                           "$type": "dimension" },
    "card-text":      { "$value": "0.92rem",                          "$type": "dimension" }
  },
  "letterSpacing": {
    "tight":   { "$value": "0.03em", "$type": "dimension" },
    "normal":  { "$value": "0.06em", "$type": "dimension" },
    "wide":    { "$value": "0.1em",  "$type": "dimension" },
    "heading": { "$value": "0.15em", "$type": "dimension" }
  },
  "radius": {
    "sm": { "$value": "2px", "$type": "dimension" },
    "md": { "$value": "3px", "$type": "dimension" },
    "lg": { "$value": "4px", "$type": "dimension" }
  },
  "transition": {
    "standard": { "$value": "0.3s ease", "$type": "duration" },
    "snappy":   { "$value": "0.2s ease", "$type": "duration" }
  }
}
